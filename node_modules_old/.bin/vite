#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/tmp/game-nm/2886f531-c4d0-41c0-ba48-6b7aa8a5ccdf/agent_1/.pnpm-vs/vite@7.3.3/node_modules/vite/node_modules:/tmp/game-nm/2886f531-c4d0-41c0-ba48-6b7aa8a5ccdf/agent_1/.pnpm-vs/vite@7.3.3/node_modules:/mnt/efs-game/sessions/2886f531-c4d0-41c0-ba48-6b7aa8a5ccdf/agent_1/.pnpm-vs/node_modules"
else
  export NODE_PATH="/tmp/game-nm/2886f531-c4d0-41c0-ba48-6b7aa8a5ccdf/agent_1/.pnpm-vs/vite@7.3.3/node_modules/vite/node_modules:/tmp/game-nm/2886f531-c4d0-41c0-ba48-6b7aa8a5ccdf/agent_1/.pnpm-vs/vite@7.3.3/node_modules:/mnt/efs-game/sessions/2886f531-c4d0-41c0-ba48-6b7aa8a5ccdf/agent_1/.pnpm-vs/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../vite/bin/vite.js" "$@"
else
  exec node  "$basedir/../vite/bin/vite.js" "$@"
fi
